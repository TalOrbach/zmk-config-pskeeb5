// Custom pskeeb5 ZMK keymap - ported from Vial a.vil

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/mouse.h>
#include <dt-bindings/zmk/bt.h>

// Key positions (pskeeb5 shield, matches LAYOUT_split_3x5_4):
//   0-4:   left top row
//   5-9:   right top row
//  10-14:  left home row
//  15-19:  right home row
//  20-24:  left bottom row
//  25-29:  right bottom row
//  30-33:  left thumb (4 keys)
//  34-37:  right thumb (4 keys)

/ {
    behaviors {
        // Hold-tap for home row mods
        ht: ht {
            display-name = "Home Row Mod";
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            bindings = <&kp>, <&kp>;
        };

        // Layer-tap (hold=MO, tap=KP)
        lt: lt {
            display-name = "Layer Tap";
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <200>;
            quick-tap-ms = <200>;
            bindings = <&mo>, <&kp>;
        };

        // --- Tap Dances ---

        // TD(0): SPACE on tap, MO(2) on hold, M0 on double-tap (250ms)
        td0: td0 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_SPC";
            #binding-cells = <0>;
            tapping-term-ms = <250>;
            bindings = <&kp SPACE>, <&mo 2>, <&m0>;
        };

        // TD(2): ENTER on tap, = on hold (200ms)
        td2: td2 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_ENT";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp ENTER>, <&kp EQUAL>, <&kp ENTER>;
        };

        // TD(5): / on tap, \ on hold (250ms)
        td5: td5 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_SLH";
            #binding-cells = <0>;
            tapping-term-ms = <250>;
            bindings = <&kp FSLH>, <&kp BSLH>, <&kp FSLH>;
        };

        // TD(6): Q on tap, ESC on hold, GRAVE on double-tap (200ms)
        td6: td6 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_Q";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp Q>, <&kp ESC>, <&kp GRAVE>;
        };

        // TD(7): - on tap, , on hold (200ms)
        td7: td7 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_MIN";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp MINUS>, <&kp COMMA>, <&kp MINUS>;
        };

        // TD(8): F1 on tap, ESC on hold (200ms)
        td8: td8 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_F1";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp F1>, <&kp ESC>, <&kp F1>;
        };

        // TD(12): DF(2) on tap, DF(0) on hold (200ms)
        td12: td12 {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_L2";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&to 2>, <&to 0>, <&to 0>;
        };

        // --- Encoder behaviors ---

        // Rotary encoder: mouse scroll
        rot_msc: rot_msc {
            compatible = "zmk,behavior-sensor-rotate-var";
            #sensor-binding-cells = <2>;
            bindings = <&msc>, <&msc>;
            tap-ms = <20>;
        };

        // Rotary encoder: mouse button press
        rot_btn: rot_btn {
            compatible = "zmk,behavior-sensor-rotate-var";
            #sensor-binding-cells = <2>;
            bindings = <&mkp>, <&mkp>;
            tap-ms = <20>;
        };
    };

    // --- Combos ---
    combos {
        compatible = "zmk,combos";
        // E + R = TAB
        combo_tab {
            timeout-ms = <50>;
            key-positions = <1 2>;
            bindings = <&kp TAB>;
            layers = <0>;
        };
        // BTN1 + BTN2 = BTN3 - positions shifted by thumb remap, disabled for now
        combo_mclk {
            timeout-ms = <50>;
            key-positions = <30 34>;
            bindings = <&mkp MCLK>;
            layers = <7>;
        };
    };

    // --- Macros ---
    macros {
        // M0: tap KP_DOT then SPACE
        m0: m0 {
            compatible = "zmk,behavior-macro";
            label = "M0";
            #binding-cells = <0>;
            bindings = <&macro_tap &kp KP_DOT &kp SPACE>;
        };
    };

    // ==================== KEYMAP ====================
    keymap {
        compatible = "zmk,keymap";

        // Layer 0 — Base (custom layout: left columns remapped, right standard)
        default_layer {
            display-name = "Base";
            bindings = <
//      left top                  right top
//  T       R     E/lt2    W     Q/td6   Y       U       I       O     P/lt3
    &kp T    &kp R &lt 2 E  &kp W &td6    &kp Y    &kp U    &kp I    &kp O &lt 3 P
//      left home                  right home
//  G/sgui  F/gui  D/alt  S/ctrl  A/sft  H/lt4  J/rgui  K/ralt  L/rctrl '/rsft
    &ht LGUI G &ht LGUI F &ht LALT D &ht LCTRL S &ht LSHFT A   &lt 4 H  &ht RGUI J &ht RALT K &ht RCTRL L &ht RSHFT SQT
//      left bottom                 right bottom
//  B/lt5  V/lt5  C/lt4  X       Z       N/lt5  M/lt4  ,       .       TD(5)
    &lt 5 B  &lt 5 V &lt 4 C  &kp X  &kp Z   &lt 5 N  &lt 4 M &kp COMMA &kp DOT &td5
//      left thumb (4 keys)         right thumb (4 keys)
//   DF0    lt2(TAB)  USER00 lt7(`)  MUTE   BTN1    lt3(-)  TD(0)
    &none  &none  &to 0  &lt 2 TAB   &mkp LCLK  &lt 3 MINUS  &td0  &kp C_MUTE
            >;
            sensor-bindings = <&rot_msc SCRL_DN SCRL_UP &inc_dec_kp C_VOL_UP C_VOL_DN>;
        };

        // Layer 1 — Numbers + Navigation
        num_layer {
            display-name = "NumNav";
            bindings = <
//   5   4   3   2   1    6   7   8   9   0
    &kp N5 &kp N4 &kp N3 &kp N2 &kp N1   &kp N6 &kp N7 &kp N8 &kp N9 &kp N0
//   G   F   D   S   A    LEFT DOWN UP RIGHT ;
    &kp G &kp F &kp D &kp S &kp A   &kp LEFT &kp DOWN &kp UP &kp RIGHT &kp SEMI
//   B   V   C   X   Z    N   M   ,   .   /
    &kp B &kp V &kp C &kp X &kp Z   &kp N &kp M &kp COMMA &kp DOT &kp FSLH
//   DF0  TT(3)  MO1   LGUI   TRNS  ENTER  MO2   TT(2)
    &none  &none  &to 0  &tog 3   &kp ENTER  &mo 2  &tog 2  &trans
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp LEFT RIGHT>;
        };

        // Layer 2 — Mouse/Navigation/Symbols
        mouse_layer {
            display-name = "MouseNav";
            bindings = <
//   WH_U  TRNS  TRNS  TRNS  PGUP     WH_U  HOME  UP    END   PGUP
    &msc SCRL_UP &trans &trans &trans &kp PG_UP   &msc SCRL_UP &kp HOME &kp UP &kp END &kp PG_UP
//   WH_D  TRNS  TRNS  TRNS  mt(PGDN)  WH_D  LEFT  DOWN  RIGHT PGDN
    &msc SCRL_DN &trans &trans &trans &ht LSHFT PG_DN   &msc SCRL_DN &kp LEFT &kp DOWN &kp RIGHT &kp PG_DN
//   TRNS  TRNS  TRNS  TRNS  TRNS     TD12  [     DOWN  ]     LGUI
    &trans &trans &trans &trans &trans   &td12 &kp LBKT &kp DOWN &kp RBKT &kp LGUI
//   DF0   TD12   TAB   TD12    TRNS   TD12   LCTRL  TRNS
    &none  &none  &to 0  &td12   &td12  &kp LCTRL  &trans  &trans
            >;
            // Vial: Enc0=BRIU/BRID, Enc1=LEFT/RIGHT
            sensor-bindings = <&inc_dec_kp C_BRI_UP C_BRI_DN &inc_dec_kp LEFT RIGHT>;
        };

        // Layer 3 — Symbols + Numpad
        sym_layer {
            display-name = "SymNum";
            bindings = <
//   5   4   3   2   1    6   7   8   9   0
    &kp N5 &kp N4 &kp N3 &kp N2 &kp N1   &kp N6 &kp N7 &kp N8 &kp N9 &kp N0
//   BSPC mtGui(]) mtAlt([) mtCtrl(=) mtSft(-)  KP*  4   5   6   +
    &kp BSPC &ht LGUI RBKT &ht LALT LBKT &ht LCTRL EQUAL &ht LSHFT MINUS   &kp KP_MULTIPLY &kp N4 &kp N5 &kp N6 &kp KP_PLUS
//   TRNS   <     -   SPACE TRNS    KP/  lt4(1)  2   3   TD7
    &trans &kp LS(DOT) &kp MINUS &kp SPACE &trans   &kp KP_DIVIDE &lt 4 N1 &kp N2 &kp N3 &td7
//   DF0   TO0   DEL  LOCK    TRNS   TD2   KP.  0
    &none  &none  &to 0  &to 0   &td2  &kp KP_DOT  &kp N0  &trans
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp C_VOL_DN C_VOL_UP>;
        };

        // Layer 4 — Utility (spare backspace/delete, mostly transparent)
        util_layer {
            display-name = "Utility";
            bindings = <
//   TRNS TRNS TRNS TRNS TRNS     TRNS TRNS TRNS BSPC NONE
    &trans &trans &trans &trans &trans   &trans &trans &trans &kp BSPC &none
//   TRNS TRNS TRNS TRNS TRNS     TRNS MO(2) BSPC TRNS NONE
    &trans &trans &trans &trans &trans   &trans &mo 2 &kp BSPC &trans &none
//   TRNS TRNS TRNS TRNS TRNS     TRNS TRNS DEL TRNS BSPC
    &trans &trans &trans &trans &trans   &trans &trans &kp DEL &trans &kp BSPC
//   DF0  BSPC  TRNS TRNS     TRNS  BTN3  BSPC DEL
    &none  &none  &to 0  &kp BSPC   &mkp MCLK  &kp BSPC  &kp DEL  &trans
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp LEFT RIGHT>;
        };

        // Layer 5 — F-Keys
        fkey_layer {
            display-name = "FKeys";
            bindings = <
//   F5   F4   F3   F2   TD8     F6   F7   F8   F9   F10
    &kp F5 &kp F4 &kp F3 &kp F2 &td8   &kp F6 &kp F7 &kp F8 &kp F9 &kp F10
//   TRNS mtGui(]) mtAlt([) mtCtrl(F12) mtSft(F11)  TRNS BSPC BSPC ;   :
    &trans &ht LGUI RBKT &ht LALT LBKT &ht LCTRL F12 &ht LSHFT F11       &trans &kp BSPC &kp BSPC &kp SEMI &kp LS(SEMI)
//   `    TRNS TRNS BRIU BRID     TRNS DEL TRNS TRNS ENTER
    &kp GRAVE &trans &trans &kp C_BRI_UP &kp C_BRI_DN   &trans &kp DEL &trans &trans &kp ENTER
//   DF0  TAB  VOLU VOLD     TRNS  BTN3  ENTER ENTER
    &none  &none  &to 0  &kp TAB   &mkp MCLK  &kp ENTER  &kp ENTER  &trans
            >;
            sensor-bindings = <&rot_btn MCLK MCLK &rot_btn RCLK MCLK>;
        };

        // Layer 6 — Game layer (FEDCB left, GHIJK right)
        game_layer {
            display-name = "Game";
            bindings = <
//   F   E   D   C   B     G   H   I   J   K
    &kp F &kp E &kp D &kp C &kp B   &kp G &kp H &kp I &kp J &kp K
//   F   E   D   C   B     G   H   I   J   K
    &kp F &kp E &kp D &kp C &kp B   &kp G &kp H &kp I &kp J &kp K
//   F   E   D   C   B     G   H   I   J   K
    &kp F &kp E &kp D &kp C &kp B   &kp G &kp H &kp I &kp J &kp K
//   DF0  3   2   4     TRNS  7   5   6
    &none  &none  &to 0  &kp N3   &kp N7  &kp N5  &kp N6  &trans
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp LEFT RIGHT>;
        };

        // Layer 7 — Mouse + Grave
        mouse2_layer {
            display-name = "Mouse2";
            bindings = <
//   TRNS TRNS TRNS TRNS GRAVE     BTN2  WH_L TRNS TRNS TRNS
    &trans &trans &trans &trans &kp GRAVE   &mkp RCLK &msc SCRL_LEFT &trans &trans &trans
//   TRNS TRNS TRNS TRNS TRNS     TRNS TRNS TRNS TRNS TRNS
    &trans &trans &trans &trans &trans   &trans &trans &trans &trans &trans
//   TRNS TRNS TRNS TRNS TRNS     TRNS BTN3 TRNS TRNS TRNS
    &trans &trans &trans &trans &trans   &trans &mkp MCLK &trans &trans &trans
//   DF0  TRNS TRNS TRNS     TRNS TRNS USER05 BTN2
    &none  &none  &to 0  &trans   &trans  &none  &mkp RCLK  &trans
            >;
            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP &inc_dec_kp LEFT RIGHT>;
        };
    };
};
